{
  "name": "s10-telemedicine-desktop",
  "version": "1.0.0",
  "description": "Desktop application for S10 Telemedicine",
  "main": "main.js",
  "author": "S10 Technologies",
  "license": "MIT",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
     "build:win": "electron-builder --win nsis",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac --publish never",
    "build:all": "electron-builder  --win nsis --linux --mac"
  },

  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },

  "build": {
    "appId": "in.s10.telemedicine",
    "productName": "S10 Telemedicine",

    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },

    "files": [
      "main.js",
      "package.json"
    ],

    "asar": true,

    "win": {
  "target": [
    {
      "target": "nsis",
      "arch": ["x64"]
    }
  ],
  "icon": "assets/icon.ico"
},

"nsis": {
  "oneClick": false,
  "allowToChangeInstallationDirectory": true,
  "createDesktopShortcut": true,
  "createStartMenuShortcut": true,
  "shortcutName": "S10 Telemedicine",
  "runAfterFinish": true
},

    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.medical",
      "icon": "assets/icon.icns"
    },

    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}